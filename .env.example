# --- Supabase ---
# Project URL from Supabase Project Settings > API
SUPABASE_URL=
# anon/public key from Supabase Project Settings > API
SUPABASE_ANON_KEY=
# service_role key from Supabase Project Settings > API
SUPABASE_SERVICE_ROLE_KEY=
# Database connection string from Supabase Project Settings > Database
DATABASE_URL=

# --- Frontend (VITE_ prefix for Vite exposure) ---
# Same as SUPABASE_URL and SUPABASE_ANON_KEY above
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Resend ---
# API key from https://resend.com > API Keys
RESEND_API_KEY=

# --- Backend ---
PORT=3000
