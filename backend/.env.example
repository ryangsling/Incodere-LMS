# Backend
PORT=3000
NODE_ENV=development

# Supabase (https://supabase.com)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database (Supabase Settings > Database)
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Resend (https://resend.com) - transactional email
RESEND_API_KEY=re_...

# Verified sender address (verify your domain at resend.com/domains)
# For local dev, you can use the default test sender: onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=ILMS by incodet

# Frontend URL (used in CORS allowlist and email links)
FRONTEND_URL=http://localhost:5173

# Comma-separated extra origins allowed via CORS (production deployments)
ALLOWED_ORIGINS=https://ilms-incodet.vercel.app
